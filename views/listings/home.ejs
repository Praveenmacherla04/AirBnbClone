<% layout('./layout/boilerplate.ejs') %>

<div class="container mt-5">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Welcome to WanderLust</h1>
        <p class="lead text-muted">
            Discover amazing places to stay around the world.
        </p>

        <a href="/listings" class="btn btn-dark btn-lg mt-3">
            Explore Listings
        </a>
    </div>

    <!-- Featured Section -->
    <div class="row text-center mt-5">

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-3">
                <div class="card-body">
                    <h4>🏡 Unique Stays</h4>
                    <p class="text-muted">
                        Find cozy homes, cottages, apartments, and luxury stays.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-3">
                <div class="card-body">
                    <h4>🌍 Explore Anywhere</h4>
                    <p class="text-muted">
                        Discover beautiful destinations across the world.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-3">
                <div class="card-body">
                    <h4>💰 Affordable Prices</h4>
                    <p class="text-muted">
                        Stay within your budget without compromising comfort.
                    </p>
                </div>
            </div>
        </div>

    </div>

</div>